#!/bin/bash
#
# NIS2 Field Audit Tool - Simple Launcher
#

set -e

# Resolve the real path of this script (handles symlinks)
SCRIPT_SOURCE="${BASH_SOURCE[0]}"
while [ -L "$SCRIPT_SOURCE" ]; do
    SCRIPT_DIR="$(cd "$(dirname "$SCRIPT_SOURCE")" && pwd)"
    SCRIPT_SOURCE="$(readlink "$SCRIPT_SOURCE")"
    [[ $SCRIPT_SOURCE != /* ]] && SCRIPT_SOURCE="$SCRIPT_DIR/$SCRIPT_SOURCE"
done
SCRIPT_DIR="$(cd "$(dirname "$SCRIPT_SOURCE")" && pwd)"

# Use virtual environment if available
if [ -d "$SCRIPT_DIR/.venv" ]; then
    PYTHON_EXE="$SCRIPT_DIR/.venv/bin/python3"
else
    PYTHON_EXE="python3"
fi

# If no arguments, run the TUI, otherwise run the CLI
if [ $# -eq 0 ]; then
    exec "$PYTHON_EXE" "$SCRIPT_DIR/run.py"
else
    # Check if first arg is 'tui' or 'dashboard'
    if [ "$1" == "tui" ] || [ "$1" == "dashboard" ]; then
        shift
        exec "$PYTHON_EXE" "$SCRIPT_DIR/run.py" "$@"
    else
        # Run the CLI
        exec "$PYTHON_EXE" -m app.cli "$@"
    fi
fi
