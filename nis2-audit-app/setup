#!/bin/bash
#
# NIS2 Audit Tool - One-Click Setup for Uncle
# Just run: ./setup
#

echo "🔧 Setting up NIS2 Field Audit Tool..."
echo ""

# Go to script directory
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$SCRIPT_DIR"

# Install Python package if needed
if ! command -v nis2-audit-server &> /dev/null; then
    echo "📦 Installing Python backend..."
    pip3 install --break-system-packages -e . 2>/dev/null || pip3 install -e . --user 2>/dev/null || {
        echo "⚠️  Could not install Python package automatically"
        echo "   Try: pip3 install -e $SCRIPT_DIR"
    }
fi

# Create symlink for easy access
echo "🔗 Creating shortcut..."
mkdir -p ~/.local/bin
ln -sf "$SCRIPT_DIR/nis2-audit" ~/.local/bin/nis2-audit 2>/dev/null || true

# Check if ~/.local/bin is in PATH
if [[ ":$PATH:" != *":$HOME/.local/bin:"* ]]; then
    echo ""
    echo "⚠️  ~/.local/bin is not in your PATH"
    echo "   Add this to your ~/.bashrc or ~/.zshrc:"
    echo "   export PATH=\"\$HOME/.local/bin:\$PATH\""
    echo ""
    echo "   Then run: source ~/.bashrc  (or restart terminal)"
fi

echo ""
echo "✅ Done! Start the tool with:"
echo "   $SCRIPT_DIR/nis2-audit"
echo ""
echo "   Or if ~/.local/bin is in your PATH:"
echo "   nis2-audit"
echo ""
