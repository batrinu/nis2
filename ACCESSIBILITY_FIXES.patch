def action_next(self):
    """Go to next question or show completion message."""
    self._save_current_response()
    section = self.sections[self.current_section]
    
    # Check if at end of all sections
    is_last_section = self.current_section == len(self.sections) - 1
    is_last_question = self.current_question == len(section.questions) - 1
    
